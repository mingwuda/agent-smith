/* ─── Step 0: 标题页 ─── */
.intro-cover {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
  gap: var(--space-5);
  padding-top: var(--space-7);
}
.intro-masthead {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
}
.intro-brand {
  font-family: var(--font-display-en);
  font-size: var(--t-body);
  color: var(--text-2);
  letter-spacing: 0.08em;
}
.intro-issue {
  font-family: var(--font-mono);
  font-size: var(--t-small);
  color: var(--text-mute);
}
.intro-cover-body {
  display: flex;
  flex-direction: column;
  gap: var(--space-5);
  padding-top: var(--space-6);
}
.intro-cover-h {
  font-size: var(--t-display-1);
  line-height: 1.05;
  margin: 0;
  max-width: 28ch;
  text-shadow: 0 2px 20px rgba(255, 74, 43, 0.25);
}
.intro-cover-foot {
  margin-top: var(--space-7);
  display: flex;
  align-items: center;
  gap: var(--space-3);
  font-family: var(--font-mono);
  font-size: var(--t-small);
  color: var(--text-mute);
}

/* ─── Step 1: 项目定位 ─── */
.intro-position {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
  gap: var(--space-5);
  padding-top: var(--space-7);
}
.intro-position-h {
  font-size: var(--t-display-2);
  line-height: 1.15;
  margin: 0;
  max-width: 32ch;
}
.intro-position-p {
  font-family: var(--font-body);
  font-size: var(--t-body);
  line-height: 1.7;
  color: var(--text-2);
  max-width: 56ch;
  margin: 0;
}

/* ─── Step 2: 技术栈 ─── */
.intro-tech {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
  gap: var(--space-5);
  padding-top: var(--space-7);
}
.intro-tech-h {
  font-size: var(--t-h1);
  line-height: 1.2;
  margin: 0;
  max-width: 40ch;
}
.intro-tech-tags {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-4);
  margin-top: var(--space-4);
}
.intro-tag {
  font-family: var(--font-mono);
  font-size: var(--t-small);
  padding: var(--space-2) var(--space-4);
  border: 1px solid var(--rule);
  border-radius: 2px;
  color: var(--text-2);
  background: var(--surface);
  animation: tagFadeIn 0.6s ease-out both;
}
.intro-tag:nth-child(1) { animation-delay: 0.1s; }
.intro-tag:nth-child(2) { animation-delay: 0.25s; }
.intro-tag:nth-child(3) { animation-delay: 0.4s; }
.intro-tag:nth-child(4) { animation-delay: 0.55s; }

@keyframes tagFadeIn {
  from { opacity: 0; transform: translateY(8px); }
  to { opacity: 1; transform: translateY(0); }
}

/* ─── Step 3: 后端架构图 ─── */
.intro-arch {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
  gap: var(--space-5);
  padding-top: var(--space-7);
}
.intro-arch-diagram {
  display: flex;
  align-items: center;
  gap: var(--space-4);
  margin-top: var(--space-6);
}
.intro-arch-node {
  font-family: var(--font-mono);
  font-size: var(--t-body);
  padding: var(--space-4) var(--space-6);
  border: 1px solid var(--rule);
  background: var(--surface);
  color: var(--text);
  min-width: 120px;
  text-align: center;
}
.intro-arch-fastapi {
  border-color: var(--accent);
  color: var(--accent);
}
.intro-arch-langgraph {
  border-color: var(--accent-soft);
  color: var(--accent-soft);
}
.intro-arch-model {
  border-color: var(--text-mute);
  color: var(--text-mute);
}
.intro-arch-arrow {
  flex-shrink: 0;
  width: 120px;
  height: 24px;
}
.intro-arch-svg {
  width: 100%;
  height: 100%;
  overflow: visible;
}
.intro-arch-line {
  stroke: var(--text-mute);
  stroke-width: 1;
  stroke-dasharray: 4 2;
  animation: dashFlow 1.5s linear infinite;
}
.intro-arch-head {
  fill: var(--text-mute);
}
@keyframes dashFlow {
  to { stroke-dashoffset: -12; }
}
.intro-arch-p {
  font-family: var(--font-body);
  font-size: var(--t-small);
  color: var(--text-mute);
  margin: 0;
  margin-top: var(--space-4);
}
.intro-arch-h {
  font-size: var(--t-h1);
  line-height: 1.2;
  margin: 0;
  max-width: 40ch;
}
.intro-arch-layer {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: var(--space-2);
}
.intro-arch-layer-title {
  font-family: var(--font-mono);
  font-size: var(--t-micro);
  letter-spacing: var(--track-caps);
  text-transform: uppercase;
  color: var(--text-mute);
}
.intro-arch-user {
  border-color: var(--text);
  color: var(--text);
}
.intro-arch-wechat {
  border-color: var(--accent-soft);
  color: var(--accent-soft);
}
.intro-arch-tools {
  margin-top: var(--space-6);
  display: flex;
  flex-direction: column;
  gap: var(--space-3);
}
.intro-arch-tools-title {
  font-family: var(--font-mono);
  font-size: var(--t-micro);
  letter-spacing: var(--track-caps);
  text-transform: uppercase;
  color: var(--text-mute);
}
.intro-arch-tool-list {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-3);
}
.intro-arch-tool {
  font-family: var(--font-mono);
  font-size: var(--t-small);
  padding: var(--space-2) var(--space-4);
  border: 1px solid var(--rule);
  background: var(--surface);
  color: var(--text-2);
  border-radius: 2px;
}

/* ─── Step 4: 前端体验 ─── */
.intro-frontend {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
  gap: var(--space-5);
  padding-top: var(--space-7);
}
.intro-mock-ui {
  border: 1px solid var(--rule);
  background: var(--surface);
  border-radius: 4px;
  overflow: hidden;
  max-width: 640px;
  margin-top: var(--space-5);
  animation: mockSlideIn 0.7s ease-out both;
}
@keyframes mockSlideIn {
  from { opacity: 0; transform: translateY(12px); }
  to { opacity: 1; transform: translateY(0); }
}
.intro-mock-header {
  display: flex;
  align-items: center;
  gap: var(--space-3);
  padding: var(--space-3) var(--space-4);
  border-bottom: 1px solid var(--rule);
  background: var(--surface-2);
}
.intro-mock-dot {
  width: 10px;
  height: 10px;
  border-radius: 50%;
  background: var(--accent);
  animation: dotPulse 2s ease-in-out infinite;
}
@keyframes dotPulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.4; }
}
.intro-mock-title {
  font-family: var(--font-mono);
  font-size: var(--t-small);
  color: var(--text-2);
}
.intro-mock-body {
  padding: var(--space-4) var(--space-5);
  display: flex;
  flex-direction: column;
  gap: var(--space-3);
}
.intro-mock-user {
  font-family: var(--font-body);
  font-size: var(--t-small);
  color: var(--text-2);
}
.intro-mock-ai {
  display: flex;
  flex-direction: column;
  gap: var(--space-2);
  padding-left: var(--space-4);
  border-left: 2px solid var(--accent-soft);
}
.intro-mock-thinking {
  font-family: var(--font-mono);
  font-size: var(--t-small);
  color: var(--text-mute);
  animation: blink 1.2s steps(2, start) infinite;
}
.intro-mock-tool {
  font-family: var(--font-mono);
  font-size: var(--t-small);
  color: var(--accent-soft);
}
.intro-mock-result {
  font-family: var(--font-mono);
  font-size: var(--t-small);
  color: var(--text);
}
@keyframes blink {
  to { visibility: hidden; }
}

/* ─── Step 5: 模型兼容 ─── */
.intro-models {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
  gap: var(--space-5);
  padding-top: var(--space-7);
}
.intro-models-h {
  font-size: var(--t-h1);
  line-height: 1.2;
  margin: 0;
  max-width: 36ch;
}
.intro-model-list {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-5);
  margin-top: var(--space-5);
}
.intro-model-item {
  font-family: var(--font-display-en);
  font-size: var(--t-h2);
  color: var(--accent);
  opacity: 0;
  animation: modelSlideIn 0.7s ease-out forwards;
}
.intro-model-item:nth-child(1) { animation-delay: 0.15s; }
.intro-model-item:nth-child(2) { animation-delay: 0.35s; }
.intro-model-item:nth-child(3) { animation-delay: 0.55s; }
.intro-model-item:nth-child(4) { animation-delay: 0.75s; }

@keyframes modelSlideIn {
  from { opacity: 0; transform: translateX(-16px); }
  to { opacity: 1; transform: translateX(0); }
}

/* ─── Step 6: 能力矩阵 ─── */
.intro-abilities {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
  gap: var(--space-5);
  padding-top: var(--space-7);
}
.intro-ability-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: var(--space-4);
  margin-top: var(--space-5);
  max-width: 720px;
}
.intro-ability-item {
  font-family: var(--font-body);
  font-size: var(--t-small);
  padding: var(--space-4) var(--space-3);
  border: 1px solid var(--rule);
  background: var(--surface);
  text-align: center;
  opacity: 0;
  animation: abilityPop 0.5s ease-out forwards;
}
.intro-ability-item:nth-child(1) { animation-delay: 0.05s; }
.intro-ability-item:nth-child(2) { animation-delay: 0.12s; }
.intro-ability-item:nth-child(3) { animation-delay: 0.19s; }
.intro-ability-item:nth-child(4) { animation-delay: 0.26s; }
.intro-ability-item:nth-child(5) { animation-delay: 0.33s; }
.intro-ability-item:nth-child(6) { animation-delay: 0.40s; }
.intro-ability-item:nth-child(7) { animation-delay: 0.47s; }
.intro-ability-item:nth-child(8) { animation-delay: 0.54s; }
.intro-ability-item:nth-child(9) { animation-delay: 0.61s; }
.intro-ability-wechat {
  border-color: var(--accent-soft);
  color: var(--accent-soft);
}

@keyframes abilityPop {
  from { opacity: 0; transform: scale(0.92); }
  to { opacity: 1; transform: scale(1); }
}

/* ─── Step 7: 微信 Bot 接入流程 ─── */
.intro-wechat {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
  gap: var(--space-5);
  padding-top: var(--space-7);
}
.intro-wechat-h {
  font-size: var(--t-h1);
  line-height: 1.2;
  margin: 0;
  max-width: 40ch;
}
.intro-wechat-steps {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: var(--space-5);
  margin-top: var(--space-5);
  max-width: 960px;
}
.intro-wechat-step {
  border: 1px solid var(--rule);
  background: var(--surface);
  padding: var(--space-5) var(--space-4);
  opacity: 0;
  animation: wechatStepIn 0.6s ease-out forwards;
}
.intro-wechat-step:nth-child(1) { animation-delay: 0.1s; }
.intro-wechat-step:nth-child(2) { animation-delay: 0.25s; }
.intro-wechat-step:nth-child(3) { animation-delay: 0.4s; }
.intro-wechat-step-num {
  font-family: var(--font-mono);
  font-size: var(--t-h2);
  color: var(--accent);
  line-height: 1;
}
.intro-wechat-step-title {
  font-family: var(--font-body);
  font-size: var(--t-body);
  color: var(--text);
  margin-top: var(--space-3);
}
.intro-wechat-step-desc {
  font-family: var(--font-body);
  font-size: var(--t-small);
  color: var(--text-2);
  margin-top: var(--space-2);
  line-height: 1.6;
}
.intro-wechat-flow {
  display: flex;
  align-items: center;
  gap: var(--space-3);
  margin-top: var(--space-5);
  flex-wrap: wrap;
}
.intro-wechat-flow-node {
  font-family: var(--font-mono);
  font-size: var(--t-small);
  padding: var(--space-2) var(--space-4);
  border: 1px solid var(--accent-soft);
  color: var(--accent-soft);
  background: var(--surface);
}
.intro-wechat-flow-arrow {
  font-family: var(--font-mono);
  font-size: var(--t-body);
  color: var(--text-mute);
}
@keyframes wechatStepIn {
  from { opacity: 0; transform: translateY(10px); }
  to { opacity: 1; transform: translateY(0); }
}


.intro-code {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
  gap: var(--space-5);
  padding-top: var(--space-7);
}
.intro-code-block {
  font-family: var(--font-mono);
  font-size: var(--t-body);
  line-height: 1.8;
  background: var(--surface);
  border: 1px solid var(--rule);
  padding: var(--space-5) var(--space-6);
  max-width: 560px;
  margin-top: var(--space-4);
}
.intro-code-line {
  white-space: pre;
}
.intro-code-comment {
  color: var(--text-mute);
}
.intro-code-keyword {
  color: var(--accent);
}
.intro-code-string {
  color: var(--accent-soft);
}


.intro-skills {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
  gap: var(--space-5);
  padding-top: var(--space-7);
}
.intro-skill-list {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-4);
  margin-top: var(--space-5);
}
.intro-skill-card {
  font-family: var(--font-mono);
  font-size: var(--t-small);
  padding: var(--space-3) var(--space-5);
  border: 1px solid var(--rule);
  background: var(--surface);
  color: var(--text-2);
  opacity: 0;
  animation: skillFlip 0.6s ease-out forwards;
}
.intro-skill-card:nth-child(1) { animation-delay: 0.1s; }
.intro-skill-card:nth-child(2) { animation-delay: 0.25s; }
.intro-skill-card:nth-child(3) { animation-delay: 0.4s; }
.intro-skill-card:nth-child(4) { animation-delay: 0.55s; }

@keyframes skillFlip {
  from { opacity: 0; transform: rotateX(20deg) translateY(8px); }
  to { opacity: 1; transform: rotateX(0deg) translateY(0); }
}


.intro-multi {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
  gap: var(--space-5);
  padding-top: var(--space-7);
}
.intro-multi-diagram {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: var(--space-4);
  margin-top: var(--space-5);
}
.intro-user-node {
  font-family: var(--font-mono);
  font-size: var(--t-small);
  padding: var(--space-2) var(--space-5);
  border: 1px solid var(--rule);
  background: var(--surface);
  color: var(--text-2);
  opacity: 0;
  animation: userFadeIn 0.5s ease-out forwards;
}
.intro-user-node:nth-child(1) { animation-delay: 0.1s; }
.intro-user-node:nth-child(2) { animation-delay: 0.3s; }
.intro-user-node:nth-child(3) { animation-delay: 0.5s; }
.intro-user-wechat {
  border-color: var(--accent-soft);
  color: var(--accent-soft);
}


@keyframes memoryPulse {
  0%, 100% { box-shadow: 0 0 0 0 rgba(255, 74, 43, 0); }
  50% { box-shadow: 0 0 0 6px rgba(255, 74, 43, 0.15); }
}

/* ─── Step 8: 文件与代码 ─── */
.intro-code {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
  gap: var(--space-5);
  padding-top: var(--space-7);
}
.intro-code-block {
  font-family: var(--font-mono);
  font-size: var(--t-body);
  line-height: 1.8;
  background: var(--surface);
  border: 1px solid var(--rule);
  padding: var(--space-5) var(--space-6);
  max-width: 560px;
  margin-top: var(--space-4);
}
.intro-code-line {
  white-space: pre;
}
.intro-code-comment {
  color: var(--text-mute);
}
.intro-code-h {
  font-size: var(--t-h1);
  line-height: 1.2;
  margin: 0;
  max-width: 40ch;
}
.intro-code-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: var(--space-4);
  margin-top: var(--space-5);
  max-width: 800px;
}
.intro-code-card {
  border: 1px solid var(--rule);
  background: var(--surface);
  padding: var(--space-4) var(--space-5);
  opacity: 0;
  animation: codeCardIn 0.5s ease-out forwards;
}
.intro-code-card:nth-child(1) { animation-delay: 0.1s; }
.intro-code-card:nth-child(2) { animation-delay: 0.2s; }
.intro-code-card:nth-child(3) { animation-delay: 0.3s; }
.intro-code-card:nth-child(4) { animation-delay: 0.4s; }
.intro-code-card-title {
  font-family: var(--font-mono);
  font-size: var(--t-small);
  color: var(--accent);
  margin-bottom: var(--space-2);
}
.intro-code-card-desc {
  font-family: var(--font-body);
  font-size: var(--t-small);
  color: var(--text-2);
  line-height: 1.6;
}
@keyframes codeCardIn {
  from { opacity: 0; transform: translateY(8px); }
  to { opacity: 1; transform: translateY(0); }
}
  font-family: var(--font-body);
  font-size: var(--t-small);
  color: var(--text-2);
  line-height: 1.6;







@keyframes cardSlideUp {
  from { opacity: 0; transform: translateY(18px); }
  to { opacity: 1; transform: translateY(0); }
}
.intro-scene-card-title {
  font-family: var(--font-body);
  font-size: var(--t-body);
  color: var(--text);
}

/* ─── Step 12: 结尾 ─── */
.intro-end {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  gap: var(--space-5);
  padding-top: var(--space-7);
  text-align: center;
}
.intro-end-h {
  font-size: var(--t-display-2);
  line-height: 1.2;
  margin: 0;
  max-width: 28ch;
}
.intro-end-cursor {
  font-family: var(--font-mono);
  font-size: var(--t-h1);
  color: var(--accent);
  animation: cursorBlink 1s steps(1) infinite;
  margin-top: var(--space-4);
}
@keyframes cursorBlink {
  0%, 100% { opacity: 1; }
  50% { opacity: 0; }
}
